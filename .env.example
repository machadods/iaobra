# ============================================================
# IAOBRAS - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# DATABASE (já configurado e rodando)
DATABASE_URL=postgresql://postgres:musashi@127.0.0.1:5434/iaobras_db
DATABASE_ECHO=False

# ============================================================
# IA - OpenRouter (Gemini grátis)
# Crie sua chave em: https://openrouter.ai/keys
# Modelo gratuito: google/gemini-2.0-flash-exp:free
# ============================================================
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ============================================================
# AUTENTICAÇÃO - Primeiro acesso (mestre admin padrão)
# ============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=iaobras2024

# ============================================================
# APP
# ============================================================
APP_NAME=IAOBRA
APP_VERSION=0.2.0
DEBUG=True
