import streamlit as st
from style import load_css

def render():
    load_css()

    st.markdown("<div class='title'>🏗️ Minhas Obras</div>", unsafe_allow_html=True)

    obras = [
        {"nome": "Casa do Seu Carlos", "etapas": "Reboco em andamento"},
        {"nome": "Reforma da Loja Central", "etapas": "Pintura iniciada"},
        {"nome": "Garagem do João", "etapas": "Fundação concluída"},
    ]

    for obra in obras:
        st.markdown(f"""
        <div class='card'>
            <h3 style='color:white;'>📌 {obra['nome']}</h3>
            <p class='subtitle'>Status: {obra['etapas']}</p>
            <div class='btn'>Abrir Obra</div>
        </div>
        """, unsafe_allow_html=True)
